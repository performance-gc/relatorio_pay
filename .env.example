# ============================================================================
# CENTRAL FARMA | PAINEL OPERACIONAL — variáveis de ambiente
# ============================================================================

# --- Fonte dos dados ---------------------------------------------------------
# Em DEV local (sua IP liberada no SG da RDS): use DIRECT_DB.
# Em PROD (Vercel): use N8N_WEBHOOK.
DATA_SOURCE=DIRECT_DB
# DATA_SOURCE=N8N_WEBHOOK

# --- DIRECT_DB (somente DEV) -------------------------------------------------
MYSQL_HOST=your-rds-host.us-east-1.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=changeme
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=changeme

# --- N8N_WEBHOOK (PROD) ------------------------------------------------------
N8N_WEBHOOK_URL=https://integracao-n8n.grupocentralbrasil.com.br/webhook/painel-pagamentos
N8N_WEBHOOK_SECRET=troque-por-uma-senha-forte

# --- Janela de busca ---------------------------------------------------------
# Quantos dias para trás considerar (default 30)
LOOKBACK_DAYS=30

# --- Supabase Auth -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# --- Bypass de auth em DEV ---------------------------------------------------
# Quando true, pula o middleware do Supabase. NUNCA usar em prod.
BYPASS_AUTH=true
